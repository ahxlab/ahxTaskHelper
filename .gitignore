*.e2e

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NCrunch
*.ncrunch*
.*crunch*.local.xml

# NuGet Packages Directory
# We exclude the whole packages directory by default. 
# If you want to commit your packages, comment out the line below.
packages/*
# But keep the build directory in the packages folder since NuGet packages use it for MSBuild targets
!packages/*/build/

# Click-Once directory
publish/

# Publish Web Output
*.Publish.xml
*.pubxml
*.publishsettings

# Others
sql/
*.Cache
ClientBin/
~$*
*~
*.dbmdl
*.pfx

# Backup & report files from converting an old project file to a newer
# Visual Studio version.
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# SQL Server files
App_Data/*.mdf
App_Data/*.ldf
App_Data/*.sda

# LightSwitch generated files
GeneratedArtifacts/
_Pvt_Extensions/
ModelManifest.xml

# Node.js (if applicable)
node_modules/

# =========================
# Windows detritus
# =========================

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# macOS desktop service store files
.DS_Store

